# Optional override for staging / alternate host (no trailing slash).
# Production builds default to https://guardamarhotelspa.com when unset (see site.js SITE_ORIGIN_DEFAULT).
# VITE_SITE_ORIGIN=https://staging.example.com

# Google Search Console → Settings → Ownership verification → HTML tag (content value only).
# Injected as <meta name="google-site-verification" ...> on production build.
# VITE_GOOGLE_SITE_VERIFICATION=your_token_here
